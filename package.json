{
  "name": "greppable-explorer",
  "version": "0.1.0",
  "description": "Visual explorer for GDL (Grep-native Data Language) projects",
  "bin": {
    "greppable-explorer": "./bin/greppable-explorer.mjs"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 4321",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "gdl",
    "greppable",
    "explorer",
    "agentic",
    "grep",
    "code-map",
    "schema"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/greppable/greppable-explorer.git"
  },
  "files": [
    "bin/",
    "src/",
    "next.config.ts",
    "tsconfig.json",
    "postcss.config.mjs",
    "components.json"
  ],
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "open": "^10.1.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^2.1.9",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
